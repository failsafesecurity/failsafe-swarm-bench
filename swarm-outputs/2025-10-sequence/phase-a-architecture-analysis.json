    "asset_inventory": {
      "financial_assets": [
        "Native ETH held by each Wallet proxy address (can be sent/received via Calls.execute/selfExecute, ERC-4337 deposits, Hooks.receive, Guest fallback execution)",
        "ERC-20 tokens held by Wallet proxy address (movable via Calls.execute/selfExecute to arbitrary token contracts)",
        "ERC-721 / ERC-1155 NFTs held by Wallet proxy address (movable via Calls.execute/selfExecute; receiver hooks implemented in Hooks)",
        "ERC-777 tokens (Hooks.tokensReceived implemented; Wallet may receive tokens and later transfer via Calls.execute)",
        "ERC-4337 EntryPoint deposit attributed to the wallet address (funded in validateUserOp via EntryPoint.depositTo)"
      ],
      "state_assets": [
        "Implementation pointer stored at storage slot `sstore(address(), _imp)` (proxy delegates to this implementation) [Implementation.sol]",
        "Nonce mapping: NONCE_KEY => mapping(space => nonce) [Nonce.sol]",
        "Reentrancy status: STATUS_KEY [ReentrancyGuard.sol]",
        "Wallet config image hash (Stage1 uses CREATE2-derived validity; Stage2 stores IMAGE_HASH_KEY) [Stage1Auth.sol, Stage2Auth.sol]",
        "Static signature registry: STATIC_SIGNATURE_KEY => mapping(opHash => (authorizedCaller, expiryTimestamp)) [BaseAuth.sol]",
        "Hooks registry: HOOKS_KEY => mapping(selector => implementation) [Hooks.sol]",
        "Explicit session usage limits: limitUsage[wallet][usageHash] [PermissionValidator.sol]",
        "Recovery queues: timestampForQueuedPayload[wallet][signer][payloadHash], queuedPayloadHashes[wallet][signer][] [Recovery.sol]",
        "Session configuration-derived Merkle/imageHash (computed from encoded session permissions, blacklist, identity signer) [SessionSig.sol]"
      ],
      "privilege_assets": [
        "Ability to execute arbitrary calls / delegatecalls from the wallet via Calls.execute/selfExecute (gated by signatureValidation or onlySelf)",
        "Ability to set/remove hooks (delegatecall routing) via Hooks.addHook/removeHook (onlySelf)",
        "Ability to upgrade wallet implementation via Implementation.updateImplementation (onlySelf); Stage1Auth also forces upgrade to Stage2 implementation upon first image update",
        "Ability to update signer configuration imageHash via BaseAuth.updateImageHash (onlySelf) and static signature entries via BaseAuth.setStaticSignature (onlySelf)",
        "Ability for EntryPoint to trigger execution via ERC4337v07.executeUserOp (entrypoint-only) and to force wallet to fund deposit via validateUserOp",
        "Ability to advance nonces per space via Calls.execute (valid signature required) or via any internal selfExecute flows (onlySelf)"
      ],
      "reputation_assets": [
        "Signer threshold/weight configuration integrity (BaseSig-derived imageHash and checkpoint ordering)",
        "Session key reputation and usage-limit accounting (PermissionValidator limitUsage; SessionManager validation)",
        "Recovery signer timelock expectations (Recovery queue and _recoverBranch verification)",
        "Protocol trust in hook system correctness (Hooks fallback delegatecall to arbitrary implementations installed by wallet)"
      ]
