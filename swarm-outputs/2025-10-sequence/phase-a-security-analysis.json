    "vulnerability_patterns": [
      {
        "swc_id": "SWC-130",
        "pattern": "Out-of-bounds Read / Parsing Discrepancy",
        "locations": [
          "PermissionValidator.sol: validatePermission",
          "LibBytes.sol: readBytes32"
        ],
        "severity": "high",
        "evidence": "LibBytes.readBytes32 uses calldataload without checking if the read offset is within the bounds of the call.data slice. It reads directly from the underlying transaction calldata.",
        "exploitation_method": "An attacker crafts a payload with a short call.data and appends arbitrary bytes to the payload. The PermissionValidator reads these appended bytes to satisfy permission rules, while the target contract receives the short call.data and pads it with zeros, bypassing the intended permission constraints.",
        "affected_assets": [
          "Assets protected by session key permissions"
        ]
      },
      {
        "swc_id": "SWC-112",
        "pattern": "Delegatecall to Untrusted Callee",
        "locations": [
