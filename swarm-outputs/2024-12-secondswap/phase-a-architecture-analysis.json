  "analysis": {
    "asset_inventory": {
      "financial_assets": [
        "ERC20 payment tokens held transiently by SecondSwap_Marketplace during spotPurchase() (baseAmount + buyerFee), then distributed to seller and feeCollector",
        "USDT (IERC20) penalty fees collected in SecondSwap_Marketplace.unlistVesting() and transferred to feeCollector",
        "Vested token allocations escrowed as vesting balances inside SecondSwap_StepVesting (token balances held by vesting contracts themselves)",
        "Underlying vested ERC20 tokens custodied by each SecondSwap_StepVesting contract (deposited from tokenIssuer via safeTransferFrom in _createVesting, later paid out via claim())"
      ],
      "state_assets": [
        "SecondSwap_Marketplace.listings[vestingPlan][listingId] (seller, total, balance, pricePerUnit, discount settings, whitelist, minPurchaseAmt, status, currency, listTime)",
        "SecondSwap_Marketplace.nextListingId[vestingPlan] (listing id nonce per vesting plan)",
        "SecondSwap_Marketplace.isTokenSupport[token] (supported payment currency allowlist)",
        "SecondSwap_Marketplace.marketplaceSetting (pointer to config contract controlling admin, fee settings, freeze flag, feeCollector, vestingManager, whitelistDeployer, usdt)",
        "SecondSwap_MarketplaceSetting global config params: buyerFee, sellerFee, penaltyFee, minListingDuration, referralFee, isMarketplaceFreeze, feeCollector, s2Admin, whitelistDeployer, vestingManager, usdt",
        "SecondSwap_VestingManager.vestingSettings[vesting] (sellable, maxSellPercent, buyerFee override, sellerFee override) [struct defined in IVestingManager]",
        "SecondSwap_VestingManager.allocations[user][vesting] (bought, sold) used to enforce max sell percent",
        "SecondSwap_VestingManager.marketplace (authorized marketplace address)",
        "SecondSwap_VestingManager.s2Admin (admin address)",
        "SecondSwap_VestingManager.vestingDeployer (authorized deployer address for setSellable)",
        "SecondSwap_VestingDeployer.manager, s2Admin, _tokenOwner[owner]=>token mapping gating vesting deployment and vesting operations",
        "SecondSwap_StepVesting per-plan immutable schedule params: token, startTime, endTime, numOfSteps, stepDuration; and authority addresses: tokenIssuer, manager, vestingDeployer",
        "SecondSwap_StepVesting._vestings[beneficiary] (stepsClaimed, amountClaimed, releaseRate, totalAmount)",
        "SecondSwap_Whitelist.maxWhitelist, totalWhitelist, lotOwner, userSettings[address]"
      ],
      "privilege_assets": [
        "SecondSwap_MarketplaceSetting.s2Admin: can change fees, freeze marketplace, change feeCollector, whitelistDeployer, vestingManager, and transfer admin to new address",
        "SecondSwap_Marketplace.addCoin()/setMarketplaceSettingAddress(): gated by settings.s2Admin (indirect admin control of marketplace behavior and supported currencies)",
        "SecondSwap_VestingManager.s2Admin: can set marketplace address, change admin, set vestingDeployer, set per-vesting buyer/seller fee overrides",
        "SecondSwap_VestingManager.marketplace: exclusive right to call listVesting/unlistVesting/completePurchase/getVestingTokenAddress",
        "SecondSwap_VestingManager.setSellable(): callable by s2Admin OR vestingDeployer (enables trading for a vesting plan)",
        "SecondSwap_VestingManager.setMaxSellPercent(): callable by tokenIssuer of a specific SecondSwap_StepVesting plan",
        "SecondSwap_VestingDeployer.s2Admin: can set token owners, change manager, change admin (controls who may deploy vesting plans and create/transfer vestings)",
        "SecondSwap_VestingDeployer._tokenOwner mapping: confers issuer-like authority to deploy vestings and manipulate vesting schedules for the associated token",
        "SecondSwap_StepVesting authorities: tokenIssuer/manager/vestingDeployer can createVestings/createVesting/transferVesting (can arbitrarily create and reallocate vestings, subject to internal checks)",
        "SecondSwap_Whitelist.lotOwner: can raise maxWhitelist and indirectly control private-sale eligibility"
      ],
      "reputation_assets": [
        "Marketplace integrity of listings (price/discount/minPurchase/whitelist) and execution correctness affects protocol trust",
        "Vesting allocation accounting correctness in VestingManager.allocations and StepVesting._vestings impacts user entitlements and perceived fairness",
        "Freeze/penalty configuration correctness (MarketplaceSetting) affects user confidence and operational reliability",
        "Admin key security for s2Admin across Setting/VestingManager/VestingDeployer (governance/operations trust)"
      ]
    },
