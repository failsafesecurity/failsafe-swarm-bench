    "vulnerability_patterns": [
      {
        "swc_id": "SWC-105",
        "pattern": "Flawed Staking Pool Accounting (Share Dilution / Theft)",
        "locations": [
          "AbsBoldStakingPool.sol: withdrawFromPool",
          "AbsBoldStakingPool.sol: depositIntoPool",
          "AssertionStakingPool.sol: createAssertion",
          "EdgeStakingPool.sol: createEdge"
        ],
        "severity": "high",
        "evidence": "The `depositBalance` mapping is not decremented when tokens are transferred out of the pool to the Rollup or EdgeChallengeManager during `createAssertion` or `createEdge`. If the assertion/edge loses and the stake is slashed, the pool's token balance becomes 0, but users' `depositBalance` remains unchanged. If a new user deposits tokens into the pool, an existing user can immediately call `withdrawFromPool` to withdraw the new user's tokens, effectively stealing them to cover their own slashed stake.",
        "exploitation_method": "1. Attacker deposits into a pool and creates a doomed assertion/edge. 2. The stake is slashed. 3. Attacker waits for or tricks a victim into depositing into the same pool. 4. Attacker calls `withdrawFromPool` to drain the victim's newly deposited tokens.",
        "affected_assets": [
          "User ERC20 tokens deposited into AssertionStakingPool and EdgeStakingPool"
        ]
      }
    ],
