      ],
      "privilege_assets": [
        "Rollup proxy admin (via UUPSNotUpgradeable/_getAdmin(), returned by owner())",
        "Pausable state in RollupCore (paused/unpaused) affecting whenNotPaused gating of critical flows",
        "Validator whitelist and validatorWhitelistDisabled flag controls who can call validator-gated functions",
        "anyTrustFastConfirmer authority to fastConfirmAssertion/fastConfirmNewAssertion (bypasses normal confirmation checks)",
        "Sequencer/batch poster privileges are in SequencerInbox (external), but affect rollup message ordering/inclusion",
        "EdgeChallengeManager initialization authority (initializer) sets assertionChain/oneStepProofEntry and staking parameters; mis-init impacts security and funds flow",
        "Excess stake receiver (excessStakeReceiver) receives immediate forwarded stakes for rival L0 edges"
      ],
      "reputation_assets": [
