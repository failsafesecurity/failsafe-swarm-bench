    "vulnerability_patterns": [
      {
        "swc_id": "SWC-131",
        "pattern": "State Inconsistency / Integer Underflow",
        "locations": [
          "IdentityStaking.sol: release()",
          "IdentityStaking.sol: withdrawSelfStake()",
          "IdentityStaking.sol: withdrawCommunityStake()"
        ],
        "severity": "critical",
        "evidence": "In the `release` function, `amount` is restored but `userTotalStaked` is not updated. When the user later calls `withdrawSelfStake` or `withdrawCommunityStake`, the line `userTotalStaked[msg.sender] -= amount` will underflow and revert, permanently locking the released funds in the contract.",
        "exploitation_method": "A user who has been slashed and subsequently released will be unable to withdraw their funds once the lock period expires, as the withdrawal transaction will revert due to an arithmetic underflow.",
        "affected_assets": [
          "User staked GTC tokens"
        ]
      },
      {
        "swc_id": "SWC-114",
        "pattern": "Transaction Order Dependence (Front-Running)",
        "locations": [
          "IdentityStaking.sol: slash()",
          "IdentityStaking.sol: withdrawSelfStake()",
          "IdentityStaking.sol: withdrawCommunityStake()"
        ],
        "severity": "medium",
        "evidence": "Unlocked stakes are still subject to slashing. However, there is no mechanism to prevent a user from withdrawing their unlocked stake when they see a pending `slash` transaction in the mempool.",
        "exploitation_method": "A malicious user monitors the mempool for `slash` transactions targeting their address. If their stake is unlocked, they front-run the `slash` with a `withdraw` transaction, successfully escaping the penalty.",
        "affected_assets": [
          "Protocol slashing mechanism / GTC tokens meant to be slashed"
        ]
      },
      {
        "swc_id": "SWC-135",
        "pattern": "Logic Error / State Manipulation",
        "locations": [
          "IdentityStaking.sol: slash()"
        ],
        "severity": "low",
        "evidence": "In `slash()`, if `sStake.slashedInRound == currentSlashRound - 1`, the previous slash amount is moved to `currentSlashRound`. This allows a slasher to indefinitely delay the burning of a user's slashed funds by repeatedly slashing them in subsequent rounds.",
        "exploitation_method": "A slasher can call `slash` on a user who already has a pending slash from the previous round. Even if the user's remaining balance is 0, the slash will roll over the pending `slashedAmount` to the new round, resetting the appeal/burn timer.",
        "affected_assets": [
          "Slashed GTC tokens pending burn"
        ]
      }
    ],
