    "asset_inventory": {
      "financial_assets": [
        "ERC20 GTC token balances held by IdentityStaking contract (staked principal)",
        "Slashed-but-not-yet-burned GTC tracked in contract accounting (implicitly still held by contract until lockAndBurn transfers out)",
        "Burn flow destination: burnAddress receives ERC20 transfers on burn"
      ],
      "state_assets": [
        "userTotalStaked[address] => uint88 (aggregate staked amount per user across self + community stakes)",
        "selfStakes[address] => Stake {unlockTime,uint88 amount,uint88 slashedAmount,uint16 slashedInRound}",
        "communityStakes[staker][stakee] => Stake {unlockTime,amount,slashedAmount,slashedInRound}",
        "currentSlashRound => uint16 (round counter)",
        "burnRoundMinimumDuration => uint64 (minimum time between burns / appeal window floor)",
        "lastBurnTimestamp => uint256 (last burn timestamp used for gating lockAndBurn)",
        "burnAddress => address (recipient of burned tokens)",
        "totalSlashed[round] => uint88 (aggregate slashed amount per round)",
        "token => IERC20 (staked token address)",
        "AccessControl role membership and admin relationships (DEFAULT_ADMIN_ROLE, SLASHER_ROLE, RELEASER_ROLE, PAUSER_ROLE)",
        "Pausable state (paused/unpaused)"
      ],
      "privilege_assets": [
        "DEFAULT_ADMIN_ROLE: can grant/revoke roles and authorize UUPS upgrades (_authorizeUpgrade)",
        "PAUSER_ROLE: can pause/unpause, halting staking/withdraw/slash/burn/release via whenNotPaused",
        "SLASHER_ROLE: can reduce stake balances and move amounts into slashed accounting",
        "RELEASER_ROLE: can reverse slashes (within allowed rounds) by moving from slashedAmount back to amount",
        "UUPS upgrade authority gated by DEFAULT_ADMIN_ROLE (upgradeTo/upgradeToAndCall via proxy)",
        "Role admin privileges inherent in AccessControlUpgradeable (grantRole/revokeRole/renounceRole)",
        "Potential ability to freeze upgrades (UUPSUpgradeable) if upgrade mechanism disabled in future implementations (not present here, but noted by comment)"
      ],
      "reputation_assets": [
        "Implied identity/reputation backing from selfStake amounts (used externally by consumers of IIdentityStaking data)",
        "Implied community vouching reputation from communityStakes (stake on others)",
        "Governance/voting power is not managed by IdentityStaking, but underlying GTC token may carry delegation/votes (in test token GTC.sol)"
      ]
    },
