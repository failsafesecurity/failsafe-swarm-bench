  },
  "analysis": {
    "asset_inventory": {
      "financial_assets": [
        "No direct custody of ETH/ERC-20/NFT assets in analyzed hook contracts; they act as authorization/constraint middleware for lending markets",
        "Indirect financial control: ability to block/unblock deposits/withdrawals/transfers via hook outcomes, affecting asset flows in associated Market contracts",
        "Protocol fee and interest parameter gating via MarketConstraintHooks.onSetAnnualInterestAndReserveRatioBips (indirectly impacts lender yield/borrower cost)"
      ],
      "state_assets": [
        "FixedTermLoanHooks._lenderStatus / AccessControlHooks._lenderStatus: per-lender credential metadata (blocked flag, lastProvider, canRefresh, lastApprovalTimestamp)",
        "FixedTermLoanHooks.isKnownLenderOnMarket / AccessControlHooks.isKnownLenderOnMarket: per (lender, market) boolean used to bypass future withdrawal/transfer checks",
        "FixedTermLoanHooks._pullProviders / AccessControlHooks._pullProviders: array of pull role providers (iterated for credential refresh)",
        "FixedTermLoanHooks._roleProviders / AccessControlHooks._roleProviders: mapping providerAddress => packed RoleProvider config (TTL, providerAddress, pull index)",
        "FixedTermLoanHooks._hookedMarkets / AccessControlHooks._hookedMarkets: per-market configuration (enabled, access flags, minimumDeposit; plus fixedTermEndTime for FixedTermLoanHooks)",
        "MarketConstraintHooks.temporaryExcessReserveRatio: per-market temporary reserve ratio state (original APR, original reserve ratio, expiry)",
        "HooksConfig/HooksDeploymentConfig bitfields: govern which hooks are enabled/required during market operations (used by external market contracts to call hooks)"
      ],
      "privilege_assets": [
        "Borrower (immutable) authority in FixedTermLoanHooks/AccessControlHooks: can add/remove role providers, set minimum deposit, block/unblock lenders; plus set fixed term end time (FixedTermLoanHooks)",
        "Approved Role Provider privilege: any provider present in _roleProviders mapping can call grantRole/grantRoles and (if lastProvider) revokeRole, influencing who can deposit/withdraw/receive transfers",
        "Implicit privilege: any caller that is a Market contract (msg.sender) can invoke hook entry points (onDeposit/onTransfer/onQueueWithdrawal/etc.); hooks assume caller corresponds to a configured market (isHooked)",
        "MarketConstraintHooks influence on market risk parameters: can force temporary reserve ratio increases when APR reduced (affects borrow availability and safety)"
      ],
      "reputation_assets": [
        "Lender eligibility/whitelisting reputation via credentials and isKnownLenderOnMarket stickiness (once known lender, bypasses future checks in some flows)",
        "Sanctions/credential provider trust: external role providers used for KYC/AML or accreditation affect protocol compliance reputation",
        "Market parameter integrity reputation: enforcement of bounds on APR/reserve/delinquency settings via MarketConstraintHooks"
      ]
    },
    "system_architecture": {
      "contracts_analyzed": [
        "FixedTermLoanHooks.sol",
        "AccessControlHooks.sol",
        "MarketConstraintHooks.sol",
        "RoleProvider.sol",
        "LenderStatus.sol",
        "LibDeployment.sol",
        "HooksConfig.sol",
        "MarketState.sol",
        "LibStoredInitCode.sol"
      ],
      "inheritance_hierarchy": "FixedTermLoanHooks -> MarketConstraintHooks -> IHooks. AccessControlHooks -> MarketConstraintHooks -> IHooks. MarketConstraintHooks is an abstract hooks base enforcing parameter constraints and temporary reserve ratio state. RoleProvider and LenderStatus are value-type packing libraries used by hook contracts. HooksConfig is a library used by Market contracts (not included) to call hook contracts and to merge required/optional flags. LibDeployment and LibStoredInitCode are deployment/script utilities (Foundry/FFI) and not part of onchain runtime for the lending protocol, but contain callable library functions that may be used in scripts.",
      "external_dependencies": [
        "IRoleProvider (external role provider contracts; functions: isPullProvider(), getCredential(address), validateCredential(address,bytes))",
        "IHooks (hook interface used by Market contracts to call hooks)",
        "BoolUtils (boolean helpers: and/or semantics)",
        "MathUtils (mulDiv, min/max, rayMul/rayDiv, bipMul, satAdd/satSub)",
        "SafeCastLib (uint256 to uint128 casts with checks)",
        "forge-std/Vm.sol and forge-std/console.sol (script-only, via LibDeployment)",
        "solady/utils/LibString.sol (script utilities, via LibDeployment)"
      ],
      "upgrade_patterns": "None. The analyzed onchain hook/base contracts are constructed with immutables and have no initializer logic, no proxy hooks, and no upgrade entrypoints. Deployment helpers (LibDeployment/LibStoredInitCode) support deterministic/standard deployments but are not upgrade proxies.",
      "access_control_structure": "Borrower-only admin model via immutable borrower and onlyBorrower modifier (setMinimumDeposit, setFixedTermEndTime, addRoleProvider, removeRoleProvider, blockFromDeposits, unblockFromDeposits). Provider-based authorization via _roleProviders mapping: only approved providers (non-null RoleProvider) can grantRole/grantRoles; only the lastProvider recorded on a lender can revokeRole. Hook entry points are externally callable but gated by per-market configuration: each hook checks _hookedMarkets[msg.sender].isHooked, using msg.sender as the Market contract identity."
    },
