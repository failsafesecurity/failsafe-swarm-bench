    "vulnerability_patterns": [
      {
        "swc_id": "SWC-110",
        "pattern": "Oracle Manipulation / Flawed Math",
        "locations": [
          "MagicLpAggregator.sol:latestAnswer()"
        ],
        "severity": "critical",
        "evidence": "The aggregator calculates the LP token price using `minAnswer * (baseReserve + quoteReserve) / pair.totalSupply()`. Because `baseReserve + quoteReserve` is the sum of raw token amounts, swapping the cheaper token for the more expensive token in the AMM increases this sum. This artificially inflates the reported LP token price.",
        "exploitation_method": "An attacker flash loans the cheaper token, swaps it for the more expensive token in the MagicLP pool (increasing the sum of reserves), uses the inflated LP token price to borrow excessive MIM from Cauldron, and defaults on the loan.",
        "affected_assets": [
          "Cauldron MIM liquidity",
          "MagicLP tokens"
        ]
      },
      {
        "swc_id": "SWC-110",
        "pattern": "Incorrect Validation / Denial of Service",
        "locations": [
          "FeeCollectable.sol:setFeeParameters()"
        ],
        "severity": "medium",
        "evidence": "The function checks `if (feeBips > BIPS)` instead of `if (_feeBips > BIPS)`. It validates the old state variable instead of the new input parameter.",
        "exploitation_method": "An operator can set `_feeBips` to a value greater than 10000 (e.g., 65535). The check passes because the old `feeBips` is valid. Once set, future calls to `setFeeParameters` will revert, permanently locking the invalid fee and causing `calculateFees` to revert due to underflow.",
        "affected_assets": [
          "Contracts inheriting FeeCollectable"
        ]
      },
      {
        "swc_id": "SWC-105",
        "pattern": "Unprotected Ether Withdrawal / Skimming",
        "locations": [
          "DegenBox.sol:deposit()"
        ],
        "severity": "low",
        "evidence": "The `deposit` function allows `from == address(this)` and bypasses the skim check for `USE_ETHEREUM`. It calls `IWETH.deposit{value: amount}()` using the contract's own ETH balance.",
        "exploitation_method": "If a user accidentally sends ETH to the DegenBox without using the proper deposit flow, any attacker can call `deposit` with `from = address(this)` to wrap the stuck ETH into WETH and credit it to their own account.",
        "affected_assets": [
          "Stuck ETH in DegenBox"
        ]
      }
    ],
