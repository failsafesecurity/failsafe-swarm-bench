        "affected_assets": [
          "Pool Creation"
        ]
      },
      {
        "swc_id": "SWC-118",
        "pattern": "Incorrect Access Control / Denial of Service",
        "locations": [
          "LockingMultiRewards.sol:processExpiredLocks"
        ],
        "severity": "high",
        "evidence": "The `processExpiredLocks` function has the `onlyOperators` modifier, and there is no fallback function for users to unlock their own expired locks.",
        "exploitation_method": "If the operator bot goes offline, loses its keys, or maliciously refuses to process locks, users' staked funds are permanently frozen in the contract.",
        "affected_assets": [
          "User Staked Tokens"
        ]
      },
      {
        "swc_id": "SWC-118",
        "pattern": "Centralization Risk / Rug Pull Vector",
        "locations": [
          "MagicLP.sol:setParameters"
        ],
        "severity": "critical",
        "evidence": "The `setParameters` function allows the `implementationOwner` to specify `baseOutAmount` and `quoteOutAmount`, which are transferred out of the pool to `assetTo`.",
        "exploitation_method": "A compromised or malicious admin can call `setParameters` and withdraw all base and quote tokens from the pool, stealing all Liquidity Providers' funds.",
        "affected_assets": [
          "Pool Base and Quote Tokens"
        ]
      },
      {
        "swc_id": "SWC-101",
        "pattern": "Integer Overflow",
        "locations": [
          "Math.sol:_SolveQuadraticFunctionForTrade"
        ],
        "severity": "medium",
        "evidence": "The calculation `bAbs * bAbs` can overflow `uint256` if the price `i` and trade amount `delta` are very large (e.g., `bAbs > 3.4e38`).",
        "exploitation_method": "Legitimate large trades on pools with extreme price ratios will revert due to overflow, causing a Denial of Service for those specific trades.",
        "affected_assets": [
          "Trading functionality on extreme ratio pools"
        ]
      },
      {
        "swc_id": "SWC-114",
        "pattern": "Unsafe ERC20 Operation",
        "locations": [
          "Router.sol:createPoolETH"
        ],
        "severity": "low",
        "evidence": "`address(weth).safeTransferFrom(address(this), clone, msg.value);` relies on WETH9's specific behavior that allows `src == msg.sender` without allowance.",
