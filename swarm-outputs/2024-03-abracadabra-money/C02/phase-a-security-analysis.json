        "swc_id": "SWC-101",
        "pattern": "Integer Underflow / Logic Error",
        "locations": [
          "Router.sol:_validateDecimals"
        ],
        "severity": "high",
        "evidence": "The check `quoteDecimals - baseDecimals > MAX_BASE_QUOTE_DECIMALS_DIFFERENCE` will underflow and revert in Solidity 0.8+ if `baseDecimals > quoteDecimals`.",
