    "vulnerability_patterns": [
      {
        "swc_id": "SWC-118",
        "pattern": "Logic Error / Broken Access Control",
        "locations": [
          "L2Governor.sol: execute()",
          "Governor.sol: execute()"
        ],
        "severity": "critical",
        "evidence": "The require statement allows execution if status is Succeeded, Defeated, or Expired: `require(status == ProposalState.Succeeded || status == ProposalState.Defeated || status == ProposalState.Expired)`",
        "exploitation_method": "An attacker can create a malicious proposal. Even if all voters vote against it and it becomes Defeated, the attacker can still call execute() to execute the malicious payload, completely bypassing the governance mechanism.",
        "affected_assets": [
          "All protocol assets controlled by Governance"
        ]
      },
      {
        "swc_id": "SWC-114",
        "pattern": "Transaction Order Dependence / Missing Slippage Protection",
        "locations": [
          "GenesisPool.sol: _addLiquidityAndDistribute()"
        ],
        "severity": "high",
        "evidence": "The function calls `IRouter(_router).addLiquidity` with `amountAMin` and `amountBMin` set to 0.",
        "exploitation_method": "An attacker can transfer tokens to the pair contract and call sync() before the pool launches. When the pool launches, the router will use the manipulated reserves to add liquidity at a skewed ratio, allowing the attacker to extract value via arbitrage.",
        "affected_assets": [
          "Native and Funding tokens in the Genesis Pool"
        ]
      },
      {
        "swc_id": "SWC-118",
        "pattern": "Logic Error / Typo",
        "locations": [
          "GenesisPoolManager.sol: setRouter()"
        ],
        "severity": "medium",
        "evidence": "The require statement is `require(_router == address(0), \"ZA\");` instead of `!=`.",
        "exploitation_method": "The owner can only set the router to the zero address, effectively bricking the ability to update the router to a valid new address.",
        "affected_assets": [
          "Protocol upgradeability"
        ]
      },
      {
        "swc_id": "SWC-113",
        "pattern": "DoS with Failed Call",
        "locations": [
          "GenesisPoolManager.sol: checkAtEpochFlip()"
        ],
        "severity": "medium",
        "evidence": "The function loops over `liveNativeTokens` and calls `_launchPool` which makes external calls to add liquidity. There is no try-catch block.",
        "exploitation_method": "If one pool fails to launch (e.g., due to a fee-on-transfer token causing addLiquidity to revert), the entire `checkAtEpochFlip` transaction reverts, causing a Denial of Service for all other pools waiting to launch.",
        "affected_assets": [
          "All pending Genesis Pools"
        ]
      },
      {
        "swc_id": "SWC-107",
        "pattern": "Reentrancy",
        "locations": [
          "Thenian.sol: mintPublic()"
        ],
        "severity": "low",
        "evidence": "The function calls `_mintTo` which calls `_safeMint`. `_safeMint` triggers `onERC721Received` on the recipient. The function lacks a `nonReentrant` modifier.",
        "exploitation_method": "An attacker can reenter `mintPublic` during the `onERC721Received` callback to bypass the `MAX_PER_MINT` limit per transaction, although the per-wallet limit of 15 still applies.",
        "affected_assets": [
          "Thenian NFTs"
        ]
      }
    ],
