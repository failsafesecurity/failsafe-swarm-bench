    "vulnerability_patterns": [
      {
        "swc_id": "SWC-114",
        "pattern": "Logic Error / Integration Issue",
        "locations": [
          "Bribe.sol: getReward",
          "AutoVotingEscrowManager.sol: setOriginalOwner"
        ],
        "severity": "high",
        "evidence": "In Bribe.sol, `getReward` checks `_owner == avm` where `avm` is the Manager contract, but `_owner` is the AutoVotingEscrow instance. It then uses an empty mapping `originalOwner` from the Manager. Because the condition is false, rewards are sent directly to the AutoVotingEscrow instance, which has no token withdrawal function.",
        "exploitation_method": "Users who enable auto-voting will have their bribe rewards permanently locked in the AutoVotingEscrow contract when claimed.",
        "affected_assets": [
          "Bribe reward tokens"
        ]
      },
      {
        "swc_id": "SWC-135",
        "pattern": "Logic Error / Incorrect Condition",
        "locations": [
          "VotingDelegationLib.sol: moveTokenDelegates"
        ],
        "severity": "high",
        "evidence": "The condition `ownerOfFn(tId) == srcRep` is used to filter tokens to keep in the source delegate's checkpoint. It should be `tId != _tokenId`. This causes the source delegate to lose all delegations from other users whenever a single token is transferred.",
        "exploitation_method": "An attacker can transfer, mint, or burn a token to trigger `moveTokenDelegates` and wipe out the voting power of any delegate.",
        "affected_assets": [
          "Governance voting power"
        ]
      },
      {
        "swc_id": "SWC-128",
        "pattern": "DoS with Block Gas Limit",
        "locations": [
          "AutoVotingEscrowManager.sol: getTotalVotingPower",
          "AutoVotingEscrow.sol: getTotalVotingPower"
        ],
        "severity": "medium",
        "evidence": "Iterates over all AVMs and all locks within each AVM (up to 1024 per AVM). With multiple AVMs, this will exceed the block gas limit.",
        "exploitation_method": "An attacker can create many small locks and enable auto-voting to fill up AVMs, causing `getTotalVotingPower` to revert for any caller.",
        "affected_assets": [
          "Protocol availability"
        ]
      }
    ],
