      ],
      "state_assets": [
        "VotingEscrow.locked[user]: amount, end, delegated, delegatee (principal + delegation relationships)",
        "VotingEscrow.userPointHistory[user][epoch], userPointEpoch[user] (per-user voting power history)",
        "VotingEscrow.pointHistory[epoch], globalEpoch (global voting power history)",
        "VotingEscrow.slopeChanges[timestamp] (scheduled global slope deltas)",
        "VotingEscrow.unlockOverride (global early-unlock flag)",
        "GaugeController.gauge_types_[gauge] and gauge_type_names[typeId], n_gauge_types (gauge registry and types)",
        "GaugeController.vote_user_slopes[user][gauge], vote_user_power[user], last_user_vote[user][gauge] (user voting allocations)",
        "GaugeController.points_weight[gauge][week], changes_weight[gauge][week], time_weight[gauge] (per-gauge weight history)",
        "GaugeController.points_sum[type][week], changes_sum[type][week], time_sum[type] (per-type aggregate history)",
        "GaugeController.points_total[week], time_total (global aggregate history)",
        "GaugeController.points_type_weight[type][week], time_type_weight[type] (type weight history)",
        "LendingLedger.lendingMarketWhitelist[market] (market allowlist)",
        "LendingLedger.marketInfo[market]: accCantoPerShare, secRewardsPerShare, lastRewardBlock (reward accounting)",
        "LendingLedger.userInfo[market][user]: amount, rewardDebt, secRewardDebt (user reward accounting)",
        "LendingLedger.cantoPerBlock[epochBlock] (emission schedule)",
        "LendingLedger.lendingMarketTotalBalance[market] (tracked total supply per market/gauge)",
        "LendingLedger.liquidityGauges[marketOrGauge] (bi-directional market<->gauge mapping)",
        "LendingLedger.averageBlockTime, referenceBlockNumber, referenceBlockTime (timestamp approximation parameters)",
        "LiquidityGauge ERC20 state: balances, allowances, totalSupply (gauge share token representing deposited underlying)",
        "LiquidityGauge.underlyingToken and LiquidityGauge.lendingLedger (integration configuration)"
      ],
      "privilege_assets": [
        "VotingEscrow.governance (can set governance and toggle unlockOverride)",
        "GaugeController.governance (can set governance, add/remove gauges, add types, change weights, remove gauge weights)",
        "LendingLedger.governance (can set governance, whitelist markets and deploy LiquidityGauge, setRewards, setBlockTimeParameters)",
        "Market whitelist control in LendingLedger (controls which contracts can legitimately accrue/claim rewards via update_market/sync_ledger path)",
        "Gauge registry control in GaugeController (controls which gauges are eligible to receive weight and thus rewards)"
      ],
      "reputation_assets": [
        "veCANTO voting power and historical checkpoints (governance legitimacy / snapshot correctness)",
        "Gauge weights and type weights (emission direction credibility)",
        "Market whitelist status (market legitimacy and reward eligibility)",
        "LiquidityGauge share token supply (LP position representation and transfer reputation effects)",
        "Protocol-wide reward accounting correctness (trust in rewards distribution)"
      ]
