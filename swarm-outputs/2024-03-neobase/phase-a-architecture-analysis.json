    "system_architecture": {
      "contracts_analyzed": [
        "VotingEscrow.sol",
        "GaugeController.sol",
        "LendingLedger.sol",
        "LiquidityGauge.sol",
        "Deploy.sol"
      ],
      "inheritance_hierarchy": "VotingEscrow inherits OpenZeppelin ReentrancyGuard. LiquidityGauge inherits OpenZeppelin ERC20 and ERC20Burnable (and uses SafeERC20). GaugeController and LendingLedger do not inherit other project contracts but hold references: GaugeController references VotingEscrow; LendingLedger references GaugeController and deploys LiquidityGauge instances; LiquidityGauge calls back into LendingLedger via sync_ledger in _afterTokenTransfer. Deploy.sol is a Forge script (not a production contract).",
      "external_dependencies": [
        "@openzeppelin/contracts/security/ReentrancyGuard.sol",
        "@openzeppelin/contracts/utils/math/Math.sol",
        "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol",
        "@openzeppelin/contracts/token/ERC20/ERC20.sol",
        "@openzeppelin/contracts/token/ERC20/extensions/ERC20Burnable.sol",
        "forge-std/Script.sol (deployment tooling)"
      ],
      "upgrade_patterns": "None. All core contracts use constructors and no proxy/initializer patterns are present. LiquidityGauge instances are deployed with `new` from LendingLedger (factory-like behavior).",
      "access_control_structure": "Custom `onlyGovernance` modifiers in VotingEscrow, GaugeController, and LendingLedger with a single `governance` address each. No role-based AccessControl, no pausing. Privileged functions include governance changes, gauge/type/weight management, market whitelisting, reward schedule configuration, and block-time parameter tuning. LiquidityGauge has no privileged admin functions.",
      "architecture_notes": [
        "Callback coupling: LiquidityGauge triggers LendingLedger.sync_ledger on every transfer/mint/burn, which updates rewards and balances; this creates a high-frequency external call surface and potential DoS vectors.",
        "Native token flows: VotingEscrow accepts/returns native CANTO via payable createLock/increaseAmount and call-based withdraw; LendingLedger pays native CANTO via call in claim and can receive native CANTO via receive().",
        "Reward math depends on GaugeController.gauge_relative_weight_write, which mutates GaugeController state during LendingLedger.update_market."
      ]
    },
