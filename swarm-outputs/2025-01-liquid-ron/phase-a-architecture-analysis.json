  "analysis": {
    "asset_inventory": {
      "financial_assets": [
        "Native RON held transiently in LiquidRon and LiquidProxy (during WRON unwrap/withdraw and staking interactions)",
        "WRON (wrapped RON) ERC20 held by LiquidRon (ERC4626 underlying asset) and Escrow (custody/approval source)",
        "LRON ERC20 share token (ERC4626 vault shares) minted/burned by LiquidRon",
        "Staked RON positions in Ronin staking contract, attributed to each LiquidProxy address (delegations per validator)",
        "Unclaimed staking rewards in Ronin staking contract, claimable by each LiquidProxy address",
        "Operator fee accrual tracked as operatorFeeAmount (claimable by feeRecipient)",
        "Escrow-held WRON balance intended to back pending withdrawals / prevent share-mint miscalculation"
      ],
      "state_assets": [
        "operator[address] allowlist (governs staking/reward operations)",
        "stakingProxies[index] registry and stakingProxyCount (controls delegation granularity and where funds are sent)",
        "roninStaking address (integration endpoint for staking/rewards reads/writes)",
        "wron address stored in RonHelper (WRON token used for wrap/unwrap and transfers)",
        "escrow address (Escrow contract instance controlling deposit path + WRON allowance)",
        "feeRecipient address (recipient of operator fees)",
        "operatorFee (BIPS-based fee rate) and operatorFeeAmount (accumulated fees awaiting withdrawal)",
        "withdrawalEpoch (current epoch index for request-based withdrawals)",
        "withdrawalRequestsPerEpoch[epoch][user] => { fulfilled, shares } (claims accounting)",
        "lockedSharesPerEpoch[epoch] (aggregate shares locked for epoch)",
        "statusPerEpoch[epoch] (STANDBY/FINALISED gate for claims)",
        "lockedPricePerSharePerEpoch[epoch] => { shareSupply, assetSupply } (epoch settlement rate)",
        "ValidatorTracker: validators[] list, validatorCount, validatorStakeActive, validatorIndex (set maintenance for reward/stake queries)"
      ],
      "privilege_assets": [
        "Owner (Ownable): can pause/unpause, update operators, set fees, deploy proxies, update feeRecipient",
        "Operator role set: intended to control harvesting and staking actions (harvest/delegate/undelegate/finalise epoch)",
        "Pause authority (Pausable.pause/unpause) stopping most user/operator flows guarded by whenNotPaused",
        "Escrow vault binding: Escrow._vault immutable to creator (LiquidRon) and unlimited WRON approval to vault",
        "Staking proxy vault binding: LiquidProxy.vault immutable to creator (LiquidRon) and onlyVault modifier"
      ],
      "reputation_assets": [
        "LRON share supply and implied price-per-share (sensitive to accounting correctness and fee settings)",
        "Withdrawal epoch settlement correctness (lockedPricePerSharePerEpoch) affecting user trust and solvency perception",
        "Validator set tracking correctness (validators list/pruning) impacting gas costs and reward visibility",
        "Governance/centralization perception based on owner/operator controls and feeRecipient withdrawals"
      ]
    },
    "system_architecture": {
      "contracts_analyzed": [
        "LiquidRon.sol",
        "LiquidProxy.sol",
        "ValidatorTracker.sol",
        "RonHelper.sol",
        "Pausable.sol",
        "Escrow.sol"
      ],
      "inheritance_hierarchy": "LiquidRon inherits ERC4626 (and ERC20 via ERC4626), RonHelper (WRON wrapping helpers), Pausable (custom Ownable-based pause), and ValidatorTracker (validator list management). Pausable itself inherits OpenZeppelin Ownable. LiquidProxy inherits RonHelper and implements ILiquidProxy. ValidatorTracker and RonHelper are abstract helper bases. Escrow is standalone and authorizes only its deploying vault.",
      "external_dependencies": [
        "OpenZeppelin: ERC4626, ERC20, IERC20, Ownable, Math (mulDiv)",
        "Ronin staking integration via IRoninValidator interface (claimRewards/delegate/redelegate/bulkUndelegate, reward/stake view methods)",
        "WRON token integration via IWRON interface (deposit/withdraw/transfer)",
        "ILiquidProxy interface (vault-to-proxy calls)"
      ],
      "upgrade_patterns": "None. All contracts are deployed as regular implementations with constructors; no proxy/diamond patterns present.",
      "access_control_structure": "Centralized control via Ownable owner plus a custom operator allowlist. Owner can configure operators, fees, feeRecipient, deploy new staking proxies, and pause/unpause. Operator-only functions are intended to manage staking/reward harvesting and epoch finalization; however onlyOperator modifier appears logically inverted (see entry_points notes). Escrow and LiquidProxy enforce strict caller checks (only vault)."
    },
