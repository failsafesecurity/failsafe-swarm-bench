    "asset_inventory": {
      "financial_assets": [
        "Underlying collateral token (e.g., WETH) held by Size contract (custodied after deposit)",
        "Underlying borrow token (e.g., USDC) held indirectly via Aave v3 Variable Pool (IPool) position owned by Size contract",
        "Aave aToken balance of Size contract (rebasing yield-bearing position corresponding to supplied underlyingBorrowToken)",
        "ETH temporarily held by Size contract during multicall/deposit flows (wrapped into WETH via IWETH.deposit)",
        "Protocol fees in borrow token units (swap fees, fragmentation fees) routed to feeRecipient (via internal transfers of NonTransferrableScaledToken / collateral token)",
        "Protocol fees in collateral token units on liquidation (protocolProfitCollateralToken routed to feeRecipient)",
        "Liquidator payouts in collateral token units (liquidatorProfitCollateralToken) on liquidation flows"
      ],
      "state_assets": [
        "Core storage struct State (SizeStorage.state) including: feeConfig, riskConfig, oracle, data",
        "User configuration mapping: data.users[address] => User (loanOffer, borrowOffer, openingLimitBorrowCR, allCreditPositionsForSaleDisabled)",
        "Debt positions mapping: data.debtPositions[uint256] => DebtPosition (borrower, futureValue, dueDate, liquidityIndexAtRepayment)",
        "Credit positions mapping: data.creditPositions[uint256] => CreditPosition (lender, forSale, credit, debtPositionId)",
        "Next position counters: data.nextDebtPositionId, data.nextCreditPositionId",
        "Oracle state: oracle.priceFeed, oracle.variablePoolBorrowRate, oracle.variablePoolBorrowRateUpdatedAt, oracle.variablePoolBorrowRateStaleRateInterval",
        "Token addresses and protocol dependencies in storage: data.weth, data.underlyingCollateralToken, data.underlyingBorrowToken, data.variablePool",
        "Protocol-controlled token instances in storage: data.collateralToken (NonTransferrableToken), data.borrowAToken (NonTransferrableScaledToken), data.debtToken (NonTransferrableToken)",
        "Multicall reentrancy/flow flag: data.isMulticall",
        "Role membership state (OpenZeppelin AccessControlUpgradeable): DEFAULT_ADMIN_ROLE, PAUSER_ROLE, KEEPER_ROLE, BORROW_RATE_UPDATER_ROLE",
        "Paused state (OpenZeppelin PausableUpgradeable)"
      ],
      "privilege_assets": [
        "UUPS upgrade authority via _authorizeUpgrade(): onlyRole(DEFAULT_ADMIN_ROLE)",
        "DEFAULT_ADMIN_ROLE (can grant/revoke roles, and updateConfig)",
        "PAUSER_ROLE (can pause/unpause protocol entrypoints guarded by whenNotPaused)",
        "KEEPER_ROLE (can call liquidateWithReplacement)",
        "BORROW_RATE_UPDATER_ROLE (can setVariablePoolBorrowRate; affects pricing/yield curve computations)",
        "Fee recipient address (feeConfig.feeRecipient) controls where fees accrue; updateable by admin via updateConfig",
        "Oracle price feed address (oracle.priceFeed) updateable by admin via updateConfig",
        "Risk parameters (crOpening, crLiquidation, min/max tenor, caps, minimumCredit) updateable by admin via updateConfig",
        "Ownership of protocol-controlled tokens (NonTransferrableToken/NonTransferrableScaledToken) is the Size contract address; any bug enabling arbitrary calls from Size context impacts mint/burn/transferFrom"
      ],
      "reputation_assets": [
        "User positions (credit positions / debt positions) representing lender claims and borrower obligations",
        "User loanOffer and borrowOffer yield curves (affect matching terms, perceived fairness, and market integrity)",
        "Protocol risk configuration credibility (CR thresholds, caps, fees) affecting solvency/trust",
        "Keeper reputation/operations (liquidateWithReplacement) impacting liquidation outcomes and perceived decentralization"
      ]
