    "vulnerability_patterns": [
      {
        "swc_id": "SWC-120",
        "pattern": "Weak Sources of Randomness from Chain Attributes",
        "locations": [
          "EntropyGenerator.sol: writeEntropyBatch1, writeEntropyBatch2, writeEntropyBatch3"
        ],
        "severity": "critical",
        "evidence": "Entropy values are generated using block.number and stored statically in an array. Since the array is populated once and read sequentially, the entire sequence of 10,010 entropy values is 100% predictable and public.",
        "exploitation_method": "An attacker can simulate the sequence of entropy values and front-run minting transactions to snipe tokens with the highest forge potentials and nuke factors, completely breaking the fairness of the game.",
        "affected_assets": [
          "TraitForgeNft Tokens",
          "NukeFund ETH"
        ]
      },
      {
        "swc_id": "SWC-128",
        "pattern": "Denial of Service (DoS)",
        "locations": [
          "TraitForgeNft.sol: mintWithBudget"
        ],
        "severity": "high",
        "evidence": "The while loop condition checks `_tokenIds < maxTokensPerGen`. `_tokenIds` is a global counter for all tokens ever minted, while `maxTokensPerGen` is 10,000. Once 10,000 tokens are minted across the entire protocol, this condition will permanently evaluate to false.",
        "exploitation_method": "No direct exploitation needed; the function will naturally break and permanently deny service to users attempting to use `mintWithBudget` after Generation 1 sells out.",
        "affected_assets": [
          "Protocol Minting Revenue"
        ]
      },
      {
        "swc_id": "SWC-118",
        "pattern": "Incorrect Access Control / Integration Failure",
        "locations": [
          "TraitForgeNft.sol: _incrementGeneration",
          "EntropyGenerator.sol: initializeAlphaIndices"
        ],
        "severity": "high",
        "evidence": "`TraitForgeNft._incrementGeneration` calls `entropyGenerator.initializeAlphaIndices()`. However, `initializeAlphaIndices` has the `onlyOwner` modifier. Unless `TraitForgeNft` is explicitly made the owner of `EntropyGenerator`, this call will revert.",
        "exploitation_method": "When the 10,000th token of a generation is minted, the transaction will revert due to the access control failure, permanently halting all public minting and generation progression.",
        "affected_assets": [
          "Protocol Minting Functionality"
        ]
      },
      {
        "swc_id": "SWC-101",
        "pattern": "Integer Underflow / Precision Loss",
        "locations": [
          "DevFund.sol: receive"
        ],
        "severity": "high",
        "evidence": "The calculation `uint256 amountPerWeight = msg.value / totalDevWeight;` suffers from severe precision loss. If `msg.value` is smaller than `totalDevWeight`, `amountPerWeight` becomes 0, and the entire `msg.value` is sent to the owner as `remaining`.",
        "exploitation_method": "Since DevFund receives 10% of small trading and forging fees, many incoming transfers will have small `msg.value`. These funds will bypass the developers entirely and be skimmed by the owner.",
        "affected_assets": [
          "Developer Rewards (ETH)"
        ]
      },
      {
        "swc_id": "SWC-135",
        "pattern": "Code Logic Error (Off-by-One)",
        "locations": [
          "EntityForging.sol: listForForging",
          "EntityForging.sol: forgeWithListed"
        ],
        "severity": "medium",
        "evidence": "`listForForging` checks `forgingCounts[tokenId] <= forgePotential`. If they are equal, it allows listing. `forgeWithListed` then increments the count. This allows a token to be forged `forgePotential + 1` times.",
        "exploitation_method": "A user can list their forger token when its forging count exactly equals its forge potential. Another user can forge with it, allowing the forger to exceed its intended maximum forge limit by one.",
        "affected_assets": [
          "Entity Forging Economy"
        ]
      },
      {
        "swc_id": "SWC-135",
        "pattern": "Code Logic Error (Trapped Funds)",
        "locations": [
          "EntityForging.sol: forgeWithListed"
        ],
        "severity": "low",
        "evidence": "The function checks `require(msg.value >= forgingFee)`. If a user sends more ETH than the `forgingFee`, the excess ETH is not refunded and becomes permanently trapped in the `EntityForging` contract.",
        "exploitation_method": "Accidental overpayment by users will result in lost funds, as there is no withdrawal function for trapped ETH in the contract.",
        "affected_assets": [
          "User ETH"
        ]
      }
    ],
