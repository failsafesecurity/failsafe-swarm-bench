        "ETH held by EntityForging contract during forgeWithListed (transient; distributed to forger owner and NukeFund)",
        "ETH held by DevFund contract (distributed to devs via claim)",
        "ERC721 tokens (TraitForgeNft) held by users, and temporarily escrowed by EntityTrading when listed for sale",
        "Forging fees (ETH) paid by mergers to forge with listed forgers",
        "Trading fees/taxes (ETH) paid by buyers and routed to NukeFund",
        "Minting fees (ETH) paid by minters and routed to NukeFund"
      ],
      "state_assets": [
        "TraitForgeNft: tokenEntropy[tokenId] (core trait/role/forgePotential source)",
        "TraitForgeNft: tokenCreationTimestamps[tokenId] (age calculation input)",
        "TraitForgeNft: lastTokenTransferredTimestamp[tokenId] (minimum hold / maturity input)",
        "TraitForgeNft: tokenGenerations[tokenId], currentGeneration, maxGeneration, generationMintCounts[gen], maxTokensPerGen",
        "TraitForgeNft: whitelist rootHash, whitelistEndTime (mint gating)",
        "TraitForgeNft: initialOwners[tokenId] (airdrop accounting input)",
        "TraitForgeNft: _tokenIds (global token id counter)",
        "EntityForging: listings[id], listedTokenIds[tokenId], listingCount",
        "EntityForging: forgingCounts[tokenId], lastForgeResetTimestamp[tokenId], oneYearInDays, minimumListFee, taxCut",
        "EntityTrading: listings[id], listedTokenIds[tokenId], listingCount, taxCut",
        "NukeFund: fund (internal claim pool), taxCut, defaultNukeFactorIncrease, maxAllowedClaimDivisor, nukeFactorMaxParam, minimumDaysHeld, ageMultiplier",
        "EntropyGenerator: entropySlots[0..769], lastInitializedIndex, currentSlotIndex, currentNumberIndex, slotIndexSelectionPoint, numberIndexSelectionPoint",
        "DevFund: totalDevWeight, totalRewardDebt, devInfo[user]{weight,rewardDebt,pendingRewards}"
      ],
      "privilege_assets": [
        "Owner role on TraitForgeNft (can set core addresses, whitelist params, pricing, maxGeneration, startAirdrop; indirectly controls fund routing and randomness source)",
        "Owner role on EntityForging (can set nukeFundAddress, taxCut, oneYearInDays, minimumListFee)",
        "Owner role on EntityTrading (can set nukeFundAddress, taxCut)",
        "Owner role on NukeFund (can set taxCut, minimumDaysHeld, nuke factor params, dev/dao addresses, traitForge/airdrop addresses, ageMultiplier)",
        "Owner role on EntropyGenerator (can setAllowedCaller; can initializeAlphaIndices; can pause via inherited Pausable but no external pause/unpause exposed)",
        "Owner role on DevFund (can add/update/remove dev weights; can pause via inherited Pausable but no external pause/unpause exposed)",
        "TraitForgeNft Pausable authority (inherited): internal pause state affects mint/burn/forge/transfer hooks; but no external pause/unpause exposed",
        "EntityForging/EntityTrading/NukeFund Pausable authority (inherited): contract logic gated by whenNotPaused, but no external pause/unpause exposed",
        "Allowed caller in EntropyGenerator (controls who can consume entropy via getNextEntropy; defaults to TraitForgeNft)"
      ],
      "reputation_assets": [
        "NFT rarity/traits derived from entropy (fairness/trust of trait distribution)",
        "Nuke payout fairness and solvency reputation (NukeFund fund accounting and nukeFactor rules)",
        "Marketplace integrity reputation (EntityTrading escrow/settlement correctness; listing correctness)",
        "Forging system integrity reputation (EntityForging listing correctness, annual reset, forgePotential enforcement)",
        "Developer reward distribution reputation (DevFund weight/claim correctness)"
      ]
    },
