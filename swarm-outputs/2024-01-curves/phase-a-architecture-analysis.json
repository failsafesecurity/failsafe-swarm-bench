  "analysis": {
    "asset_inventory": {
      "financial_assets": [
        "ETH held by Curves contract transiently during buy/sell fee routing (via _transferFees)",
        "ETH accumulated in FeeSplitter (holder fee pool) and paid out via claimFees/batchClaiming",
        "Externally deployed ERC20s (CurvesERC20 per subject) representing exported internal balances (18 decimals)",
        "Internal curve tokens (non-ERC20 accounting) tracked in Curves.curvesTokenBalance/curvesTokenSupply",
        "Protocol/subject/referral fee streams (ETH) routed to protocolFeeDestination, subject address, and referralFeeDestination"
      ],
      "state_assets": [
        "Curves.curvesTokenBalance[subject][holder] internal balances",
        "Curves.curvesTokenSupply[subject] internal supply per subject",
        "Curves.ownedCurvesTokenSubjects[owner] list used for transferAllCurvesTokens iteration",
        "Curves.externalCurvesTokens[subject] {name,symbol,token} ERC20 metadata + deployed token address",
        "Curves.externalCurvesToSubject[token] reverse mapping from ERC20 to subject",
        "Curves.symbolToSubject[symbol] uniqueness registry for symbols",
        "Curves.presalesMeta[subject] {startTime, merkleRoot, maxBuy}",
        "Curves.presalesBuys[subject][buyer] tracking whitelist/presale purchase totals",
        "Curves.feesEconomics {protocolFeeDestination, protocolFeePercent, subjectFeePercent, referralFeePercent, holdersFeePercent, maxFeePercent}",
        "Curves.referralFeeDestination[subject] referral payout address",
        "Security.owner and Security.managers mapping (used by Curves and FeeSplitter)",
        "FeeSplitter.curves reference (critical dependency for balanceOf/totalSupply)",
        "FeeSplitter.tokensData[token].cumulativeFeePerToken",
        "FeeSplitter.tokensData[token].userFeeOffset[account] (per-user fee checkpoint)",
        "FeeSplitter.tokensData[token].unclaimedFees[account] (accrued ETH claim amounts)",
        "FeeSplitter.userTokens[user] list used for UI/batch claiming"
      ],
      "privilege_assets": [
        "Security.owner authority (intended): setManager, transferOwnership, Curves.setFeeRedistributor, Curves.setProtocolFeePercent, Curves.setERC20Factory",
        "Security.managers authority (intended): Curves.setMaxFeePercent, Curves.setExternalFeePercent, FeeSplitter.addFees, FeeSplitter.onBalanceChange",
        "Curves token-subject privilege: onlyTokenSubject(subject) gates setReferralFeeDestination, buyCurvesTokenForPresale, setNameAndSymbol, mint",
        "CurvesERC20 Ownable ownership: Curves contract is owner of each deployed CurvesERC20 (mint/burn control)",
        "Fee routing destinations: protocolFeeDestination and per-subject referralFeeDestination (economic control)"
      ],
      "reputation_assets": [
        "Per-subject curve integrity (pricing/supply correctness) affecting user trust",
        "Whitelist/presale integrity (merkleRoot, maxBuy, startTime enforcement)",
        "Fee distribution correctness (cumulativeFeePerToken accounting) impacting holder expectations",
        "Symbol/name registry uniqueness (symbolToSubject) affecting token identity",
        "Protocol fee configuration (feesEconomics) affecting perceived fairness"
      ]
    },
    "system_architecture": {
      "contracts_analyzed": [
        "Curves.sol",
        "FeeSplitter.sol",
        "Security.sol",
        "CurvesERC20.sol",
        "CurvesERC20Factory.sol"
      ],
      "inheritance_hierarchy": "Curves inherits Security. FeeSplitter inherits Security. CurvesERC20 inherits OpenZeppelin ERC20 and Ownable. CurvesERC20Factory is standalone.",
      "external_dependencies": [
        "OpenZeppelin: Strings",
        "OpenZeppelin: MerkleProof",
        "OpenZeppelin: ERC20",
        "OpenZeppelin: Ownable",
        "OpenZeppelin: IERC20 (imported but not used in FeeSplitter)"
      ],
      "upgrade_patterns": "None (no proxy/UUPS/diamond patterns present). Contracts are deployed directly; Curves deploys CurvesERC20 instances via factory.",
      "access_control_structure": "Custom Security contract provides owner + managers roles via modifiers onlyOwner/onlyManager, but both modifiers are defective (no require/revert), so all functions using them are effectively publicly callable. Curves additionally uses onlyTokenSubject(subject) with a proper revert check. CurvesERC20 uses OpenZeppelin Ownable correctly; ownership is transferred to the Curves contract at token deployment."
    },
