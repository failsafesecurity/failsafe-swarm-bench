      "privilege_assets": [
        "UUPS upgrade authority: EURFToken._authorizeUpgrade guarded by OWNER role",
        "DEFAULT_ADMIN_ROLE / OWNER role: can grant/revoke roles via inherited AccessControl functions; controls ADMIN role adminship by default",
        "ADMIN role: can pause/unpause, blacklist/unblacklist, forceTransfer, setTrustedForwarder, setFeeFaucet, setTxFeeRate, setGaslessBasefee",
        "MASTER_MINTER role: admin of MINTER_ROLE; can updateMintingAllowance; intended to manage minters",
        "MINTER_ROLE: can mint subject to per-minter allowance; can burn own balance",
        "CONTROLLER role: can toggle safetySwitch OFF (halt mint/burn); can also toggle ON only if controller that toggled OFF or DEFAULT_ADMIN_ROLE",
        "Forwarder owner (OwnableUpgradeable): can registerRequestType and thus change what requestTypeHash values are accepted"
      ],
      "reputation_assets": [
        "Role-based governance/administration trust (OWNER/ADMIN/MASTER_MINTER/CONTROLLER) affecting compliance and supply integrity",
        "Blacklist and forced transfer capabilities (compliance reputation risk)",
        "Protocol upgrade trust via UUPS upgrades",
        "Fee policy credibility (ability to set feesFaucet, tx fee rate, gasless basefee)"
      ]
