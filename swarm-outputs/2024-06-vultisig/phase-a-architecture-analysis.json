  "analysis": {
    "asset_inventory": {
      "financial_assets": [
        "ERC20 RAISE_TOKEN held by each ILOPool during sale (investor deposits) and returned on refund",
        "ERC20 SALE_TOKEN held by each ILOPool prior to launch (project-provided sale inventory) and partially deployed into Uniswap V3 liquidity on launch; leftover refunded to project admin",
        "Uniswap V3 position (liquidity between TICK_LOWER/TICK_UPPER) owned by ILOPool (liquidity is the backing asset for NFT positions)",
        "Uniswap V3 accrued fees (token0/token1) attributable to the ILOPool position and distributed to NFT holders less performance fee",
        "Platform/performance fees implicitly collected on claims and transferred to ILOManager.FEE_TAKER",
        "ETH temporarily received by Whitelist.receive() and immediately refunded to sender (no intended ETH custody)",
        "WETH9 wrapping/unwrapping flows inside PeripheryPayments.pay() (contract may hold ETH only as part of WETH wrapping path)"
      ],
      "state_assets": [
        "ILOPool.saleInfo (hardCap, softCap, maxCapPerUser, start, end, maxSaleAmount)",
        "ILOPool.totalRaised and per-position raiseAmount accounting",
        "ILOPool _launchSucceeded / _refundTriggered lifecycle booleans (mutual exclusivity state)",
        "ILOPool position NFT state: _positions[tokenId] {liquidity, raiseAmount, feeGrowthInside0LastX128, feeGrowthInside1LastX128}",
        "ILOVest._positionVests[tokenId] {totalLiquidity, schedule[]}",
        "ILOPool _vestingConfigs (project + investor vesting configurations)",
        "ILOPool immutable-like cached configuration in ILOPoolImmutableState (MANAGER, WETH9, RAISE_TOKEN, SALE_TOKEN, ticks, sqrt ratios, cached pool key/address)",
        "ILOWhitelist allowlist state: _openToAll and EnumerableSet _whitelisted",
        "ILOManager global config: PLATFORM_FEE, PERFORMANCE_FEE, FEE_TAKER, DEFAULT_DEADLINE_OFFSET, ILO_POOL_IMPLEMENTATION, UNIV3_FACTORY, WETH9",
        "ILOManager per-project cache: _cachedProject[uniV3Pool] (admin, tokens, fee params, launchTime, refundDeadline, initial price, cached pool key)",
        "ILOManager per-project pool list: _initializedILOPools[uniV3Pool] array (addresses of deployed clones)",
        "Whitelist state: _maxAddressCap, _locked, _isSelfWhitelistDisabled, _vultisig, _oracle, _pool, _whitelistCount, _allowedWhitelistIndex, _whitelistIndex mapping, _isBlacklisted mapping, _contributed mapping",
        "Vultisig ERC20 balances/allowances; approveAndCall approval state",
        "VultisigWhitelisted _whitelistContract address used in transfer hook gating"
      ],
      "privilege_assets": [
        "ILOManager Ownable.owner() (can set fees, fee taker, pool implementation, default deadline offset, refund deadline override)",
        "ILOManager project admin per uniV3Pool (can init ILO pools, transfer project admin, claim project refunds after deadline)",
        "ILOPool MANAGER (set to ILOManager at initialize; exclusive authority to launch and claimProjectRefund)",
        "ILOPool onlyProjectAdmin (derived from ILOManager.project(...).admin) controls whitelist settings via ILOWhitelist",
        "Whitelist Ownable.owner() (controls lock flag, cap, oracle, pool, vultisig address, whitelist and blacklist, allowed index, self-whitelist enable)",
        "Vultisig/VultisigWhitelisted Ownable.owner() (can set whitelist contract in token, and any other inherited Ownable actions)",
        "UniswapV3Oracle immutables (pool/baseToken/WETH) fixed at deployment; no admin"
      ],
      "reputation_assets": [
        "Whitelist eligibility/priority via _allowedWhitelistIndex and _whitelistIndex (early access gating reputation)",
        "Investor NFT positions (ERC721) representing vesting rights and claim history (protocol accounting credibility)",
        "Project admin role and launch/refund actions impacting protocol trust",
        "Fee policy (PLATFORM_FEE / PERFORMANCE_FEE) affecting expected returns"
      ]
    },
