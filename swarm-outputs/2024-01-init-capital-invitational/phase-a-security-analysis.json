    "vulnerability_patterns": [
      {
        "swc_id": "SWC-118",
        "pattern": "Missing Ownership Validation / Access Control",
        "locations": [
          "MarginTradingHook.sol:updateOrder"
        ],
        "severity": "critical",
        "evidence": "The `updateOrder` function retrieves `Order storage order = __orders[_orderId];` but fails to assert `order.initPosId == initPosId`. It only checks that the caller's position exists and has enough collateral to satisfy the new `_collAmt`.",
        "exploitation_method": "An attacker creates their own valid position with sufficient collateral. They call `updateOrder` passing their `_posId` and the victim's `_orderId`. They modify the victim's order to have a highly favorable `limitPrice_e36`. The attacker then calls `fillOrder` to execute the modified order, extracting the victim's collateral at an artificial price.",
        "affected_assets": [
          "User collateral locked in MarginTradingHook orders"
        ]
      },
      {
        "swc_id": "SWC-114",
        "pattern": "Unprotected Fund Sweep / MEV Extraction",
        "locations": [
          "MoneyMarketHook.sol:execute"
        ],
        "severity": "medium",
        "evidence": "If a user calls `execute` with `returnNative = false` and overpays `msg.value` (e.g., during a repay operation where `repayAmt < msg.value`), the excess WETH remains in the contract. The `execute` function allows any user to set `returnNative = true`, which sweeps all WETH and ETH balances to `msg.sender`.",
        "exploitation_method": "An MEV bot monitors for transactions to `MoneyMarketHook.execute` that leave WETH/ETH in the contract. The bot immediately backruns the transaction with a call to `execute` with empty parameters and `returnNative = true` to steal the leftover funds.",
        "affected_assets": [
          "User native tokens (ETH/WETH) left in the hook"
        ]
      },
      {
        "swc_id": "SWC-135",
        "pattern": "Incompatible with Fee-on-Transfer Tokens",
        "locations": [
          "LendingPool.sol:repay"
        ],
        "severity": "low",
        "evidence": "The `repay` function calculates the required `amt` and checks `_require(amt <= IERC20(underlyingToken).balanceOf(address(this)) - _cash)`. For fee-on-transfer tokens, the actual transferred amount is less than `amt`, causing this check to revert.",
        "exploitation_method": "Users who borrow fee-on-transfer tokens will be unable to repay their debt because the strict balance check will always fail, leading to inevitable liquidation or stuck positions.",
        "affected_assets": [
          "Fee-on-transfer tokens"
        ]
      }
    ],
