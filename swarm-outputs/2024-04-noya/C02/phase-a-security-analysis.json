    "vulnerability_patterns": [
      {
        "swc_id": "SWC-101",
        "pattern": "Arithmetic Underflow in TVL Calculation (DoS)",
        "locations": [
          "AaveConnector.sol:_getPositionTVL",
          "CompoundConnector.sol:_getPositionTVL",
          "PrismaConnector.sol:_getPositionTVL",
          "Dolomite.sol:_getPositionTVL",
          "SiloConnector.sol:_getPositionTVL"
        ],
        "severity": "high",
        "evidence": "Connectors calculate TVL by subtracting debt from collateral (e.g., `return totalCollateral - totalDebt;`). If debt exceeds collateral due to interest accrual or price drops, the subtraction underflows, reverting the transaction.",
        "exploitation_method": "An underwater position will cause `TVLHelper.getTVL()` to revert entirely, freezing all vault deposits, withdrawals, and management fee calculations.",
        "affected_assets": [
          "All vault assets (Systemic DoS)"
        ]
      },
      {
        "swc_id": "SWC-128",
        "pattern": "Stuck Native ETH / Missing Payable Forwarding",
        "locations": [
          "GenericSwapAndBridgeHandler.sol:executeSwap",
          "GenericSwapAndBridgeHandler.sol:executeBridge"
        ],
        "severity": "high",
        "evidence": "The functions are marked `payable` but make external calls to `performSwapAction` and `performBridgeAction` without forwarding `msg.value` (e.g., missing `{value: msg.value}`).",
        "exploitation_method": "When native ETH is sent to execute a swap or bridge, it remains stuck in the `GenericSwapAndBridgeHandler` contract because the external call forwards 0 ETH. There is no mechanism to rescue these stuck native funds.",
        "affected_assets": [
          "Native ETH used for swaps/bridges"
        ]
      },
      {
        "swc_id": "SWC-111",
        "pattern": "Oracle Manipulation via Spot Price / Reserves",
        "locations": [
          "UNIv3Connector.sol:_getPositionTVL",
          "CamelotConnector.sol:_getPositionTVL",
          "PancakeswapConnector.sol"
        ],
        "severity": "high",
        "evidence": "`UNIv3Connector` uses `pool.slot0()` (spot price) to calculate liquidity amounts. `CamelotConnector` uses `getReserves()` to calculate LP token value.",
        "exploitation_method": "An attacker can use a flash loan to heavily skew the Uniswap V3 or Camelot pool. This artificially inflates the reported TVL of the LP position. The attacker can then mint vault shares at an inflated TVL or withdraw at a manipulated share price.",
        "affected_assets": [
          "Vault Base Tokens",
          "LP Positions"
        ]
      },
      {
        "swc_id": "SWC-135",
        "pattern": "Empty Implementation / Missing Logic",
        "locations": [
          "Watchers.sol:verifyRemoveLiquidity"
        ],
        "severity": "medium",
        "evidence": "The `verifyRemoveLiquidity` function is completely empty. It is called by `BaseConnector.sendTokensToTrustedAddress` to verify withdrawals.",
        "exploitation_method": "The Watcher mechanism is intended to monitor and revert suspicious liquidity removals. Because it is empty, any liquidity removal requested by the accounting manager automatically succeeds, bypassing the intended security guardrail.",
        "affected_assets": [
          "Vault Liquidity"
        ]
      }
    ],
