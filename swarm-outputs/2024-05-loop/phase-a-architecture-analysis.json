    "asset_inventory": {
      "financial_assets": [
        "Native ETH held by PrelaunchPoints (from lockETH/lockETHFor, WETH unwrapped to ETH, swap proceeds, and accidental receive())",
        "ERC-20 tokens held by PrelaunchPoints (allowed LRT/wrapped tokens locked via lock/lockFor; plus any arbitrary ERC20 accidentally sent)",
        "WETH (accepted and unwrapped to ETH via WETH.withdraw during locking)",
        "lpETH ERC-20 balance held by PrelaunchPoints after convertAllETH() (used to satisfy ETH claim transfers)",
        "User entitlements to receive lpETH proportional to their ETH share (tracked implicitly via balances and totalLpETH/totalSupply)",
        "Potential staked positions in lpETHVault created by claimAndStake() on behalf of users"
      ],
      "state_assets": [
        "owner (admin address)",
        "lpETH (ILpETH) contract pointer",
        "lpETHVault (ILpETHVault) contract pointer",
        "WETH immutable address pointer",
        "exchangeProxy immutable (0x Exchange Proxy) target for swaps",
        "totalSupply (aggregate locked ETH amount; used as denominator in ETH->lpETH proportional claims)",
        "totalLpETH (lpETH amount minted to this contract during convertAllETH; used as numerator in proportional claims)",
        "isTokenAllowed[token] whitelist for lockable ERC-20 tokens (including WETH)",
        "loopActivation (uint32 timestamp; initially now+120d, later set to now when setLoopAddresses is called)",
        "startClaimDate (uint32 timestamp; initially max uint32, later set to now when convertAllETH is called)",
        "TIMELOCK constant (7 days grace window after activation before convertAllETH allowed)",
        "emergencyMode (bool; bypasses withdraw timing restrictions)",
        "balances[user][token] (principal ledger for each user per token; for ETH it represents claimable share, for other tokens it is the remaining amount available to swap/claim or withdraw)"
      ],
      "privilege_assets": [
        "Owner authority to: setOwner(), setLoopAddresses(), allowToken(), setEmergencyMode(), convertAllETH(), recoverERC20()",
        "Ability to change lpETH and lpETHVault addresses prior to loopActivation (setLoopAddresses) which controls where ETH is deposited and where lpETH is staked",
        "Ability to toggle emergencyMode enabling unrestricted withdrawals at any time",
        "Ability to whitelist arbitrary ERC-20 tokens for locking (allowToken), influencing what assets the contract may custody",
        "Ability to trigger the system state transition to claims by calling convertAllETH()"
      ],
      "reputation_assets": [
        "Off-chain points/referral tracking via referral bytes32 emitted in Locked events (integrity impacts user trust and reputation even though not on-chain enforceable)",
        "Protocol liveness/trust dependent on timely owner actions (setLoopAddresses + convertAllETH), otherwise users fall back to withdrawal-only after 120 days"
      ]
    },
    "system_architecture": {
      "contracts_analyzed": [
        "PrelaunchPoints.sol"
      ],
      "inheritance_hierarchy": "PrelaunchPoints is a standalone contract (no inheritance). It uses OpenZeppelin libraries (SafeERC20, Math) and interacts with external protocol contracts via interfaces (ILpETH, ILpETHVault, IWETH) and a 0x exchangeProxy via low-level call.",
      "external_dependencies": [
        "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol",
        "@openzeppelin/contracts/utils/math/Math.sol",
        "ILpETH (external lpETH token/contract with deposit{value}(to), transfer, balanceOf, approve)",
        "ILpETHVault (external staking vault with stake(amount, beneficiary))",
        "IWETH (external WETH contract with withdraw(amount))",
        "0x Exchange Proxy (external contract called via payable(exchangeProxy).call(_swapCallData))"
      ],
      "upgrade_patterns": "None (no proxy/diamond patterns; constructor-based initialization; immutable addresses for WETH and exchangeProxy).",
      "access_control_structure": "Single-owner model using custom onlyAuthorized modifier (msg.sender == owner). No roles, no multisig enforcement, no timelock. Time-based state gating uses onlyBeforeDate/onlyAfterDate modifiers over loopActivation/startClaimDate plus emergencyMode bypass for withdraw."
    },
