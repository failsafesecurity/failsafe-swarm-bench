    "vulnerability_patterns": [
      {
        "swc_id": "SWC-120",
        "pattern": "Weak Sources of Randomness from Chain Attributes",
        "locations": [
          "LibProposing.sol: proposeBlock"
        ],
        "severity": "high",
        "evidence": "meta_.difficulty = keccak256(abi.encodePacked(block.prevrandao, b.numBlocks, block.number)); meta_.minTier = ITierProvider(...).getMinTier(uint256(meta_.difficulty));",
        "exploitation_method": "Proposers can compute the required tier off-chain before submitting a transaction. If the block requires a high-cost tier (e.g., SGX_ZKVM), they can simply withhold the proposal and wait for the next L1 block, effectively bypassing the protocol's random high-security audits.",
        "affected_assets": [
          "Protocol Security / Multi-tier Proving System"
        ]
      },
      {
        "swc_id": "SWC-105",
        "pattern": "Missing State Validation / Logic Error",
        "locations": [
          "SgxVerifier.sol: verifyProof",
          "SgxVerifier.sol: _replaceInstance"
        ],
        "severity": "medium",
        "evidence": "The function _replaceInstance does not check if newInstance == oldInstance. It simply sets instances[id] = Instance(newInstance, uint64(block.timestamp));",
        "exploitation_method": "A prover can set newInstance to be the same as oldInstance in their proof data. This resets the validSince timestamp to the current block.timestamp, allowing the SGX key to remain valid indefinitely and bypassing the intended 180-day expiry and side-channel protection key rotation requirements.",
        "affected_assets": [
          "SGX Enclave Security"
        ]
      },
      {
        "swc_id": "SWC-286",
        "pattern": "Incorrect Access Control / Privilege Escalation",
        "locations": [
          "TaikoTimelockController.sol: getMinDelay"
        ],
        "severity": "medium",
        "evidence": "return hasRole(TIMELOCK_ADMIN_ROLE, msg.sender) ? 0 : super.getMinDelay();",
        "exploitation_method": "An address with TIMELOCK_ADMIN_ROLE can bypass the minimum delay of the timelock entirely, allowing for instant execution of potentially malicious upgrades or parameter changes, breaking the trust assumption of the timelock.",
        "affected_assets": [
          "Governance / Protocol Upgrades"
        ]
      },
      {
        "swc_id": "SWC-113",
        "pattern": "DoS with Failed Call",
        "locations": [
          "AssignmentHook.sol: onBlockProposed"
        ],
        "severity": "low",
        "evidence": "_blk.assignedProver.sendEther(proverFee, MAX_GAS_PAYING_PROVER); which uses ExcessivelySafeCall but reverts the entire transaction if success is false.",
        "exploitation_method": "A malicious prover can sign an assignment, wait for a proposer to submit it, and then cause their fallback function to revert. This causes the proposer's proposeBlock transaction to revert, wasting their gas and causing a griefing DoS.",
        "affected_assets": [
          "Proposer Gas / Block Liveness"
        ]
      }
    ],
