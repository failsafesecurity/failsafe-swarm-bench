    "asset_inventory": {
      "financial_assets": [
        "ETH forwarded to Bridge via TaikoL1.depositEtherToL2 (TaikoL1 itself should not retain ETH except transiently during hooks/refunds)",
        "TKO (TaikoToken) held by TaikoL1 as liveness bonds and by TaikoL1 as validity/contest bonds (received via transferFrom in LibProving and AssignmentHook)",
        "TKO flows: livenessBond paid by assignedProver (AssignmentHook -> TaikoL1), validityBond/contestBond paid by prover/contester (LibProving -> TaikoL1), bond payouts from TaikoL1 to provers/contestors/assignedProver (LibProving/LibVerifying)",
        "Prover fees paid to assignedProver in ETH or ERC20 via AssignmentHook (from proposer/meta.coinbase via safeTransferFrom or via hook ETH balance)",
        "Hook-forwarded ETH: TaikoL1 sends all current ETH balance to each hook sequentially; residual refunded to proposer then validated via TKO balance delta check"
      ],
      "state_assets": [
        "TaikoL1.state (TaikoData.State): blocks ring buffer, transitions ring buffer, transitionIds mapping, ethDeposits ring buffer, reusableBlobs timestamps",
        "TaikoL1.state.slotA: genesisHeight, genesisTimestamp, numEthDeposits, nextEthDepositToProcess",
        "TaikoL1.state.slotB: numBlocks, lastVerifiedBlockId, provingPaused, lastUnpausedAt",
        "Block integrity anchors: TaikoData.Block.metaHash, BlockMetadata keccak, TransitionState.tier/timestamp/contester/bonds",
        "Guardian sets and approvals: Guardians.guardianIds, Guardians.guardians array, Guardians.version, Guardians.minGuardians, approvals bitmap mapping",
        "SgxVerifier registry: nextInstanceId, instances[id]={addr,validSince}, addressRegistered",
        "AddressManager name->address mappings per chainId (critical dependency injection state)",
        "Governor/Timelock state (OpenZeppelin upgradeable Governor/Timelock internal storage: proposals, voting checkpoints, timelock operations, roles)"
      ],
      "privilege_assets": [
        "UUPS upgrade authority: EssentialContract._authorizeUpgrade onlyOwner (upgradeTo/upgradeToAndCall exposed via UUPSUpgradeable)",
        "Ownership (Ownable2StepUpgradeable): owner, pendingOwner, transferOwnership/acceptOwnership",
        "Pause authority: EssentialContract.pause/unpause gated by _authorizePause; TaikoL1 overrides _authorizePause to owner or named 'chain_pauser'; AddressManager disables pause by reverting; other contracts default to onlyOwner unless overridden",
        "Address resolution control: AddressManager.setAddress onlyOwner controls all named dependencies (bridge, taiko_token, tier_provider, verifiers, signal_service, guardian_prover, proposer/proposer_one, automata attestation, rollup_watchdog, snapshooter, chain_pauser)",
        "GuardianProver: only guardians can set approvals; owner can rotate guardian set",
        "SgxVerifier: addInstances onlyOwner; deleteInstances owner or named rollup_watchdog; registerInstance permissionless but depends on resolved attestation contract",
        "TaikoToken: owner can burn from arbitrary addresses; owner or named snapshooter can snapshot"
      ],
      "reputation_assets": [
        "L2/L3 chain finality and correctness: verified blockHash/stateRoot chain in TaikoL1.state affects cross-chain trust and signal syncing",
