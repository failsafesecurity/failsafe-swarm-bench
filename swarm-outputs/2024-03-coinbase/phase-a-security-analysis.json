    "vulnerability_patterns": [
      {
        "swc_id": "SWC-121",
        "pattern": "Signature Replay / Cross-chain Replay of Implementation Upgrade",
        "locations": [
          "CoinbaseSmartWallet.sol: canSkipChainIdValidation",
          "CoinbaseSmartWallet.sol: executeWithoutChainIdValidation"
        ],
        "severity": "critical",
        "evidence": "The function `canSkipChainIdValidation` returns true for `UUPSUpgradeable.upgradeToAndCall.selector`. This allows a UserOperation containing an implementation upgrade to be executed via `executeWithoutChainIdValidation`, making it replayable across all chains.",
        "exploitation_method": "An attacker observes a legitimate wallet upgrade transaction on Chain A. They deploy a malicious implementation contract at the exact same address on Chain B (e.g., using CREATE2 or an EOA). They then replay the user's upgrade UserOperation on Chain B, upgrading the wallet to the malicious implementation and gaining full control to steal all assets.",
        "affected_assets": [
          "All assets held by the CoinbaseSmartWallet on any chain where the replay occurs"
        ]
      },
      {
        "swc_id": "SWC-113",
        "pattern": "DoS with Failed Call / Loss of Gas Refund on postOp Revert",
        "locations": [
          "MagicSpend.sol: postOp"
        ],
        "severity": "medium",
        "evidence": "In `postOp`, the unspent gas refund `(maxGasCost - actualGasCost)` is added to `withdrawable` in memory, and `_withdrawableETH[account]` is deleted. If the subsequent `forceSafeTransferETH` reverts (e.g., due to an out-of-gas error), the entire `postOp` reverts.",
        "exploitation_method": "A malicious bundler can restrict the gas limit provided to `postOp` such that it has enough gas to start but not enough to complete the `forceSafeTransferETH` fallback mechanism. This causes `postOp` to revert. The EntryPoint catches the revert, but the paymaster's state changes are undone. The user's gas refund is never added to their `_withdrawableETH` balance, resulting in a permanent loss of the refund which remains stuck in the paymaster.",
        "affected_assets": [
          "User's unspent gas refund (ETH)"
        ]
      }
    ],
