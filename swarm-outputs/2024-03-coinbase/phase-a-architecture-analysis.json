      "state_assets": [
        "MultiOwnable owner registry: nextOwnerIndex, ownerAtIndex[index] => bytes, isOwner[bytes] => bool (controls wallet authority and signature validation)",
        "CoinbaseSmartWallet initialization state inferred by nextOwnerIndex() != 0 (guards initialize)",
        "CoinbaseSmartWallet replayable nonce key constant REPLAYABLE_NONCE_KEY and nonce-key semantics (userOp.nonce >> 64)",
        "MagicSpend per-user withdrawable ETH accounting: _withdrawableETH[user] (credited during validatePaymasterUserOp, debited on postOp/withdrawGasExcess)",
        "MagicSpend per-user nonce usage bitmap: _nonceUsed[nonce][user] (anti-replay for withdraw requests; note: set during validation and withdraw)",
        "MagicSpend owner (Solady Ownable storage) used to authorize admin functions and to verify withdraw signatures",
        "MagicSpend withdraw request hash binding: includes address(this), account, block.chainid, asset, amount, nonce, expiry",
        "ERC1271 domain separator inputs: name+version, block.chainid, verifyingContract (address(this))",
        "ERC1271 replaySafeHash(messageHash) used for cross-account replay protection"
      ],
      "privilege_assets": [
        "CoinbaseSmartWallet owner privileges (MultiOwnable): ability to execute arbitrary calls, add/remove owners, authorize upgrades (UUPS)",
        "CoinbaseSmartWallet UUPS upgrade authority via _authorizeUpgrade onlyOwner (controls implementation upgrades for the proxy instance)",
        "MagicSpend contract owner privileges (Solady Ownable): ownerWithdraw (drain assets), EntryPoint deposit/withdraw/stake management",
        "MagicSpend paymaster authority via EntryPoint calling validatePaymasterUserOp/postOp (onlyEntryPoint gate)",
        "Factory deployment authority is permissionless but controls deterministic creation flow and initialization call ordering"
      ],
      "reputation_assets": [
        "4337 validation correctness (validateUserOp/validatePaymasterUserOp) impacting bundler acceptance and protocol reliability",
        "EntryPoint stake/reputation for MagicSpend as a paymaster (stake status affects inclusion and trust)",
        "Wallet signature verification integrity for ECDSA/WebAuthn and ERC-1271 (trust in authentication for funds control)"
