    "system_architecture": {
      "contracts_analyzed": [
        "FCL.sol",
        "WebAuthn.sol",
        "ERC1271.sol",
        "MultiOwnable.sol",
        "CoinbaseSmartWallet.sol",
        "MagicSpend.sol",
        "CoinbaseSmartWalletFactory.sol"
      ],
      "inheritance_hierarchy": "CoinbaseSmartWallet inherits MultiOwnable (custom multi-owner auth with ERC-7201 namespaced storage), UUPSUpgradeable (Solady UUPS / ERC1967 upgrade mechanism), Receiver (Solady receiver helpers), and ERC1271 (abstract EIP-1271 with cross-account replay protection). MagicSpend inherits Solady Ownable and implements IPaymaster for ERC-4337. Factory is standalone and uses Solady LibClone to deploy deterministic ERC1967 minimal proxies. WebAuthn is a library that depends on FreshCryptoLib (FCL) and tries RIP-7212 verifier precompile fallback. FCL is a pure/view math library for P-256 ECDSA verification using ModExp precompile.",
      "external_dependencies": [
        "Solady: accounts/Receiver.sol, utils/UUPSUpgradeable.sol, utils/SignatureCheckerLib.sol, utils/SafeTransferLib.sol, auth/Ownable.sol, utils/LibClone.sol, utils/LibString.sol",
        "OpenZeppelin: Base64.sol",
        "ERC-4337 Account Abstraction: account-abstraction/interfaces/UserOperation.sol, IPaymaster.sol, IEntryPoint.sol",
        "RIP-7212 secp256r1 verifier precompile at address(0x100) (optional / chain-dependent)",
        "EVM ModExp precompile at address(0x05)"
      ],
      "upgrade_patterns": "Per-wallet UUPS upgradeability (CoinbaseSmartWallet implementation behind an ERC1967 proxy, typically deployed via Solady LibClone.createDeterministicERC1967). MagicSpend is non-upgradeable (regular deployment). Factory is non-upgradeable. No Diamond pattern detected.",
      "access_control_structure": "CoinbaseSmartWallet: MultiOwnable provides onlyOwner (owner address or contract itself) used for add/remove owners, execute (via onlyEntryPointOrOwner), and UUPS upgrades via _authorizeUpgrade onlyOwner. EntryPoint-only functions are protected by onlyEntryPoint modifier checking msg.sender == entryPoint() hardcoded v0.6 canonical address. MagicSpend: Solady Ownable onlyOwner protects administrative withdrawals and EntryPoint stake/deposit controls; paymaster callbacks validatePaymasterUserOp and postOp restricted to onlyEntryPoint."
    },
