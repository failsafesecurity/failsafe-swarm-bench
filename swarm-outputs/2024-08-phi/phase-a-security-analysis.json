    "vulnerability_patterns": [
      {
        "swc_id": "SWC-117",
        "pattern": "Improper Cryptographic Validation",
        "locations": [
          "PhiFactory.sol: signatureClaim",
          "PhiFactory.sol: merkleClaim"
        ],
        "severity": "critical",
        "evidence": "The `mintArgs_` parameter (containing `quantity` and `imageURI`) is not included in the signed `encodeData_` or the Merkle leaf.",
        "exploitation_method": "An attacker can use a valid signature or Merkle proof intended for 1 NFT to mint up to `maxSupply` NFTs by modifying the `quantity` parameter, and can also set arbitrary URIs.",
        "affected_assets": [
          "NFT Supply",
          "Protocol Integrity"
        ]
      },
      {
        "swc_id": "SWC-105",
        "pattern": "Unprotected Ether Withdrawal",
        "locations": [
          "CuratorRewardsDistributor.sol: distribute"
        ],
        "severity": "critical",
        "evidence": "`_msgSender().safeTransferETH(royaltyfee + distributeAmount - actualDistributeAmount);` sends the calculated `royaltyfee` to the caller instead of the protocol or creator.",
        "exploitation_method": "Anyone can call `distribute(credId)` and the contract will send the accumulated royalty fees (1% of total balance) to the caller.",
        "affected_assets": [
          "Curator Rewards",
          "Protocol Royalties"
        ]
      },
      {
        "swc_id": "SWC-135",
        "pattern": "Mishandled ETH / Stuck Funds",
        "locations": [
          "PhiFactory.sol: claim",
          "PhiFactory.sol: batchClaim",
          "PhiFactory.sol: _processClaim"
        ],
        "severity": "high",
        "evidence": "`claim` calls `this.signatureClaim{value: mintFee}`. Excess `msg.value` is left in the contract. Inside `_processClaim`, `_msgSender()` is `address(this)`, so refunds are sent to the factory itself, which has no receive function, causing reverts or stuck funds.",
        "exploitation_method": "Users calling `claim` with excess ETH will lose the excess. Users calling `batchClaim` will have their refunds stuck in the factory contract.",
        "affected_assets": [
          "User ETH"
        ]
      },
      {
        "swc_id": "SWC-128",
        "pattern": "DoS with Block Gas Limit",
        "locations": [
          "CuratorRewardsDistributor.sol: distribute"
        ],
        "severity": "medium",
        "evidence": "The function fetches all curators via `credContract.getCuratorAddresses(credId, 0, 0)` and loops over them to calculate and distribute rewards.",
        "exploitation_method": "If a cred has a large number of curators, the loop will exceed the block gas limit, permanently locking the rewards in the contract.",
        "affected_assets": [
          "Curator Rewards"
        ]
      },
      {
        "swc_id": "SWC-117",
        "pattern": "Signature Replay Across Chains",
        "locations": [
          "Cred.sol: createCred"
        ],
        "severity": "medium",
        "evidence": "The `signedData_` parameter does not include `block.chainid`.",
        "exploitation_method": "A signature used to create a cred on one chain can be replayed by anyone on another chain to create the exact same cred.",
        "affected_assets": [
          "Cred Contracts"
        ]
      }
    ],
